# ============================================
# 环境变量配置模板
# ============================================
# 使用方法：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 填入你自己的真实值
#   3. .env 文件不要提交到 git（已在 .gitignore 中忽略）

# --- 服务端口 ---
PORT=3000

# --- 运行环境 ---
# development：开发环境（显示详细错误信息）
# production：生产环境（隐藏错误细节）
NODE_ENV=production

# --- 数据库连接 ---
# 格式：mysql://用户名:密码@地址:端口/数据库名
DATABASE_URL="mysql://root:your_password@localhost:3306/fitness_db"

# --- JWT 配置 ---
# JWT_SECRET：用于签名和验证 token 的密钥
# 重要：生产环境必须使用强随机字符串，不要用简单的单词！
# 可以用这个命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_please_change_me

# token 有效期（支持格式：7d=7天, 24h=24小时, 60m=60分钟）
JWT_EXPIRES_IN=7d

# --- 微信小程序配置 ---
# 在微信公众平台 → 开发管理 → 开发设置 中获取
# 注意：WX_SECRET 绝对不能泄露给任何人！
WX_APPID=wxa2eeb9f451b75ea3
WX_SECRET=your_wechat_secret_here

